{
    "version": "2.0.0",
    "options": {
        "cwd": "${workspaceFolder}"
    },
    "tasks": [
        {
            "label": "build and test",
            "type": "shell",
            "command": "case \"$BUILD_PRESET\" in '') behave Bdd/features/ ;; freertos-cross) cmake --build --preset \"$BUILD_PRESET\" --target SolidSyslogFreeRtosSingleTask ;; *) cmake --build --preset \"$BUILD_PRESET\" --target SolidSyslogTests && ctest --preset \"$BUILD_PRESET\" --verbose --tests-regex '^SolidSyslogTests$' ;; esac",
            "windows": {
                "command": "cmake --preset msvc-debug; if ($?) { cmake --build --preset msvc-debug --target SolidSyslogTests }; if ($?) { ctest --preset msvc-debug --verbose --tests-regex '^SolidSyslogTests$' }"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "configure",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "${env:BUILD_PRESET}"],
            "windows": {
                "command": "cmake",
                "args": ["--preset", "msvc-debug"]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "test (junit)",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "${env:BUILD_PRESET}", "--target", "junit"],
            "windows": {
                "command": "cmake",
                "args": ["--build", "--preset", "msvc-debug", "--target", "junit"]
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "${env:BUILD_PRESET}", "--target", "clean"],
            "windows": {
                "command": "cmake",
                "args": ["--build", "--preset", "msvc-debug", "--target", "clean"]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "run on QEMU (FreeRTOS)",
            "detail": "One-shot interactive run of the FreeRTOS SingleTask ELF under QEMU. Drives UART0 to stdio so you can type `send 1` / `quit` at the SolidSyslog> prompt. Use only in the freertos-target service.",
            "type": "shell",
            "command": "qemu-system-arm",
            "args": [
                "-M", "mps2-an385",
                "-m", "16M",
                "-display", "none",
                "-serial", "stdio",
                "-icount", "shift=auto,sleep=off,align=off",
                "-netdev", "user,id=net0",
                "-net", "nic,netdev=net0,model=lan9118",
                "-kernel", "build/freertos-cross/Example/FreeRtos/SingleTask/SolidSyslogFreeRtosSingleTask.elf"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
