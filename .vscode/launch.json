{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug SolidSyslogTests (host)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/${env:BUILD_PRESET}/Tests/SolidSyslogTests",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "miDebuggerPath": "/usr/bin/gdb",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "build and test",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug FreeRTOS SingleTask (QEMU)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "qemu",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/freertos-cross/Example/FreeRtos/SingleTask/SolidSyslogFreeRtosSingleTask.elf",
            "cpu": "cortex-m3",
            "machine": "mps2-an385",
            "armToolchainPath": "/usr/bin",
            "serverpath": "qemu-system-arm",
            "serverArgs": [
                "-netdev", "user,id=net0",
                "-net", "nic,netdev=net0,model=lan9118"
            ],
            "preLaunchTask": "build and test",
            "runToEntryPoint": "main"
        }
    ]
}
