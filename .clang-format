Language: Cpp
BasedOnStyle: LLVM
BreakBeforeBraces: Allman
IndentWidth: 4
UseTab: Never
TabWidth: 4
ColumnLimit: 120
LineEnding: LF

# Spacing
SpaceBeforeParens: ControlStatements
SpaceAroundPointerQualifiers: Both
SpaceBeforeAssignmentOperators: true
SpaceInEmptyParentheses: false
SpacesInParentheses: false
SpacesInSquareBrackets: false
SpaceAfterCStyleCast: true
SpaceBeforeCaseColon: false

# Pointer and qualifier alignment
PointerAlignment: Left
QualifierAlignment: Left

# Alignment — Clean Code: no consecutive-line alignment (pretty but weakens
# LHS↔RHS association across whitespace, and adds diff churn when a longer
# variable name re-pads its neighbours).
AlignConsecutiveAssignments: None
AlignConsecutiveDeclarations: None
AlignTrailingComments: false
AlignEscapedNewlines: Left

# Open-bracket alignment: BlockIndent uses a constant 4-space continuation
# rather than aligning to the open-paren column. Long function names no
# longer push args deep right and shift the indent column.
AlignAfterOpenBracket: BlockIndent

# Argument / parameter packing — one-per-line for every multi-line signature
# or call. AllowAll*OnNextLine: false suppresses the "all-on-the-next-line"
# continuation row so the wrap shape is consistent regardless of arg count.
BinPackArguments: false
BinPackParameters: false
AllowAllParametersOfDeclarationOnNextLine: false
AllowAllArgumentsOnNextLine: false

# Without this, clang-format will split the return type onto its own line to
# keep args packed on one continuation line. Higher penalty keeps return type
# with function name and forces the wrap inside the parens.
PenaltyReturnTypeOnItsOwnLine: 1000

# Braces and parentheses — MISRA-load-bearing:
#   InsertBraces: true        enforces MISRA 15.6 (compound-statement body)
#   RemoveParentheses: Leave  keeps MISRA 12.1 safe (don't strip explicit
#                             precedence parens)
# Do not flip either without understanding the MISRA consequence.
InsertBraces: true
RemoveParentheses: Leave

# Short constructs — never collapse. Combined with InsertBraces: true, this is
# the formatter-side enforcement of MISRA 15.6.
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: false
AllowShortBlocksOnASingleLine: Never

# Switch statements
IndentCaseLabels: true

# Blank lines
MaxEmptyLinesToKeep: 1
SeparateDefinitionBlocks: Always

# Comments — do not reflow. Protects // NOLINTNEXTLINE(...) directives and
# long context comments from being mangled by automatic wrapping at the
# 120-column limit.
ReflowComments: false

# Includes
SortIncludes: false

# Recognise extern "C" wrapper macros (see Core/Interface/ExternC.h)
MacroBlockBegin: '^EXTERN_C_BEGIN$'
MacroBlockEnd:   '^EXTERN_C_END$'
